# --- Telegram ---
# Token from @BotFather
BOT_TOKEN=123456:ABC-DEF_your_bot_token_here

# --- Database ---
# SQLAlchemy async URL. Note the +asyncpg driver.
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/wcbot

# --- Sports data (API-Football v3) ---
# Key from your API-SPORTS account: https://www.api-football.com
API_FOOTBALL_KEY=your_api_sports_key_here
API_FOOTBALL_HOST=https://v3.football.api-sports.io
LEAGUE_ID=1
SEASON=2026

# --- Misc ---
TZ=Asia/Singapore
LOG_LEVEL=INFO
